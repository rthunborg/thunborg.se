# Public Cloudflare Turnstile site key. Leave empty to hide the widget locally.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-side Turnstile secret. Leave empty to skip verification locally.
TURNSTILE_SECRET_KEY=

# SMTP settings for the contact form.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@thunborg.se

# Recipient for contact-form emails.
CONTACT_TO_EMAIL=rasmus@thunborg.se
